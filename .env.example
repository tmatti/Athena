# Required
DATABASE_URL=postgres://athena:athena@localhost:5432/athena?sslmode=disable
BRAIN_API_KEY=change-me-to-a-long-random-string

# Embeddings (default provider is OpenRouter; any OpenAI-compatible endpoint works)
EMBEDDING_API_KEY=sk-or-...
#EMBEDDING_PROVIDER=openai_compatible   # or "none" for keyword-only search
#EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
#EMBEDDING_MODEL=openai/text-embedding-3-small
#EMBEDDING_DIMENSIONS=1536

# Server
#PORT=8080
#LOG_LEVEL=info

# OAuth for MCP clients (Claude iOS/web connectors). Setting the public HTTPS
# origin enables the embedded OAuth server; leave unset for static-key-only.
# The login page uses BRAIN_API_KEY as the credential. See docs/oauth.md.
#PUBLIC_BASE_URL=https://athena.example.com
